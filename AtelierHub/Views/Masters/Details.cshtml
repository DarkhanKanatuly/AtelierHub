@model AtelierHub.Models.Master

@{
    ViewData["Title"] = @Model.Name;
}

<h1>@Model.Name</h1>

<div class="row">
    <div class="col-md-6">
        <img src="@Model.ImageUrl" class="img-fluid rounded" alt="@Model.Name" style="max-height: 400px; object-fit: cover;">
    </div>
    <div class="col-md-6">
        <h3>@Model.Specialty</h3>
        <p>@Model.Description</p>
        <p><strong>Contact:</strong> <a href="mailto:@Model.ContactEmail">@Model.ContactEmail</a></p>
        <a asp-action="Index" class="btn btn-primary">Back to List</a>
    </div>
</div>